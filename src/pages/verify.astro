---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

/*
  VERIFY A CERTIFICATE — "coming soon" placeholder for the online validation
  portal (roadmap item; presented as coming soon, NOT live). The mock form is
  intentionally disabled.
*/

const description =
  'Validate a ProofWipe certificate ID and SHA-256 log hash online — coming soon. Until then, every certificate can be checked manually against its wipe log.';
---

<BaseLayout title="Verify a certificate" description={description}>
  <section class="border-b border-border bg-panel/40">
    <div class="container-page py-16 lg:py-20">
      <p class="inline-flex items-center gap-2 rounded-full border border-warning/40 bg-warning/10 px-3 py-1 text-xs font-semibold text-warning">
        <Icon name="zap" size={13} /> Coming soon
      </p>
      <h1 class="mt-4 max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">
        Verify a certificate
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted">
        Anyone holding a ProofWipe certificate — an auditor, a buyer, a
        downstream ITAD partner — will be able to validate its ID and log hash
        here, straight from the certificate itself.
      </p>
    </div>
  </section>

  <section class="container-page grid gap-10 py-16 lg:grid-cols-2 lg:items-start lg:py-20">
    <!-- Disabled mock form -->
    <div class="card p-8" aria-labelledby="verify-form-heading">
      <h2 id="verify-form-heading" class="font-semibold">Certificate lookup</h2>
      <p class="mt-1 text-sm text-muted">Preview — not yet operational.</p>

      <div class="mt-6 space-y-5" aria-disabled="true">
        <div>
          <label for="cert-id" class="text-sm font-medium">Certificate ID</label>
          <input
            id="cert-id"
            type="text"
            disabled
            placeholder="PW-2026-XXXX-XXXX-XXXX"
            class="mt-1.5 w-full rounded-lg border border-border bg-panel px-3.5 py-2.5 font-mono text-sm text-muted placeholder:text-muted/50 disabled:cursor-not-allowed disabled:opacity-60"
          />
        </div>
        <div>
          <label for="log-hash" class="text-sm font-medium">SHA-256 log hash</label>
          <input
            id="log-hash"
            type="text"
            disabled
            placeholder="64 hexadecimal characters from the certificate footer"
            class="mt-1.5 w-full rounded-lg border border-border bg-panel px-3.5 py-2.5 font-mono text-sm text-muted placeholder:text-muted/50 disabled:cursor-not-allowed disabled:opacity-60"
          />
        </div>
        <button type="button" disabled class="btn btn-primary w-full cursor-not-allowed opacity-60">
          <Icon name="search" size={17} /> Validate — coming soon
        </button>
      </div>

      <p class="mt-5 text-xs leading-relaxed text-muted">
        Want to know when the portal goes live?
        <a href="/about#contact" class="text-accent underline-offset-2 hover:underline">Leave us your email</a>.
      </p>
    </div>

    <!-- What it will do + manual verification today -->
    <div class="space-y-6">
      <div class="card p-7">
        <h2 class="font-semibold">What the portal will confirm</h2>
        <ul class="mt-4 space-y-3 text-sm text-muted">
          <li class="flex gap-2.5">
            <Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" />
            The certificate ID was genuinely issued by ProofWipe
          </li>
          <li class="flex gap-2.5">
            <Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" />
            The SHA-256 log hash matches the recorded wipe log — proving the
            certificate hasn’t been altered since issuance
          </li>
          <li class="flex gap-2.5">
            <Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" />
            The outcome on the paper matches the outcome on record — including
            partial or cancelled wipes
          </li>
        </ul>
      </div>

      <div class="card p-7">
        <h2 class="font-semibold">Verifying a certificate today</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          Tamper evidence works offline already: every certificate carries the
          SHA-256 hash of its wipe log, and the log file ships alongside the
          certificate. Recompute the hash and compare:
        </p>
        <pre class="mt-3 overflow-x-auto rounded-md border border-border bg-panel p-3 font-mono text-xs text-text"><code>Get-FileHash .\wipe-log.json -Algorithm SHA256</code></pre>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          If the output matches the hash printed on the certificate, the log —
          and the outcome it documents — is exactly what ProofWipe recorded.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>
