---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

/*
  VERIFY A CERTIFICATE — live, fully client-side tamper check.

  Posture (owner decision 2026-07-08): integrity-only, no signing, no server,
  no registry. The page recomputes the SHA-256 of the wipe-log file in the
  browser (WebCrypto) and compares it to the hash recorded on the certificate.
  Nothing is uploaded; there is no backend to upload to.

  Copy rules honoured here: a match proves the RECORD IS UNALTERED since
  issuance. It does not prove who issued the certificate, and it does not
  prove a wipe physically occurred. Do not reintroduce "genuinely issued by
  ProofWipe" or similar origin claims.
*/

const description =
  'Check a ProofWipe certificate against its wipe log, entirely in your browser. The page recomputes the SHA-256 of the log and compares it to the certificate. Nothing is uploaded.';
---

<BaseLayout title="Verify a certificate" description={description}>
  <section class="border-b border-border bg-panel/40">
    <div class="container-page py-16 lg:py-20">
      <p class="inline-flex items-center gap-2 rounded-full border border-success/40 bg-success/10 px-3 py-1 text-xs font-semibold text-success">
        <Icon name="check" size={13} /> Runs entirely in your browser
      </p>
      <h1 class="mt-4 max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">
        Verify a certificate
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted">
        Anyone holding a ProofWipe certificate and its wipe log (an auditor, a
        buyer, a downstream ITAD partner) can confirm the pair is unaltered
        since issuance. Your files never leave this page: the hash is
        recomputed locally with your browser&rsquo;s own cryptography, and
        nothing is uploaded or stored.
      </p>

      <!-- Sample certificate: placeholder data only ("Sample Operator",
           synthetic device SAMPLE00000001) generated by the real engine so it
           genuinely PASSES this page. Never a real customer certificate. -->
      <div class="mt-8 max-w-2xl rounded-lg border border-border bg-panel/60 p-5">
        <h2 class="text-sm font-semibold text-text">Sample certificate: verify it yourself</h2>
        <p class="mt-2 text-sm text-muted">
          No certificate handy? Download this sample pair (placeholder operator
          and device data, produced by the real engine: NVMe firmware Purge,
          100% read-back verified) and load both files below: it passes. Then
          change any byte of the log and watch it fail.
        </p>
        <div class="mt-4 flex flex-wrap gap-3 text-sm">
          <a href="/samples/sample-certificate.html" download class="btn btn-secondary">Certificate (HTML)</a>
          <a href="/samples/sample-certificate-wipe-log.txt" download class="btn btn-secondary">Wipe log</a>
          <a href="/samples/sample-certificate.pdf" class="btn btn-secondary">View the PDF</a>
        </div>
      </div>
    </div>
  </section>

  <section class="container-page grid gap-10 py-16 lg:grid-cols-2 lg:items-start lg:py-20">
    <!-- Live verifier -->
    <div class="space-y-6">
      <div class="card p-8" aria-labelledby="verify-form-heading">
        <h2 id="verify-form-heading" class="font-semibold">Check a certificate + wipe log</h2>
        <p class="mt-1 text-sm text-muted">
          Select the HTML certificate and the <span class="font-mono">…-wipe-log.txt</span> file
          saved beside it.
        </p>

        <div class="mt-6 space-y-5">
          <div>
            <label for="cert-file" class="text-sm font-medium">Certificate (.html)</label>
            <input
              id="cert-file"
              type="file"
              accept=".html,.htm,text/html"
              class="mt-1.5 w-full rounded-lg border border-border bg-panel px-3.5 py-2.5 text-sm file:mr-3 file:rounded-md file:border-0 file:bg-accent/10 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-accent"
            />
          </div>
          <div>
            <label for="log-file" class="text-sm font-medium">Wipe log (…-wipe-log.txt)</label>
            <input
              id="log-file"
              type="file"
              accept=".txt,text/plain"
              class="mt-1.5 w-full rounded-lg border border-border bg-panel px-3.5 py-2.5 text-sm file:mr-3 file:rounded-md file:border-0 file:bg-accent/10 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-accent"
            />
          </div>
          <button id="verify-btn" type="button" class="btn btn-primary w-full">
            <Icon name="search" size={17} /> Verify locally
          </button>
        </div>

        <div id="verify-result" class="mt-6 hidden" aria-live="polite"></div>
      </div>

      <!-- Manual mode: older certificates without the embedded evidence block -->
      <div class="card p-8" aria-labelledby="manual-form-heading">
        <h2 id="manual-form-heading" class="font-semibold">Manual mode</h2>
        <p class="mt-1 text-sm text-muted">
          For older certificates without a machine-readable block: paste the
          SHA-256 printed on the certificate and select the log file.
        </p>
        <div class="mt-5 space-y-5">
          <div>
            <label for="manual-hash" class="text-sm font-medium">SHA-256 from the certificate</label>
            <input
              id="manual-hash"
              type="text"
              placeholder="64 hexadecimal characters from the certificate footer"
              class="mt-1.5 w-full rounded-lg border border-border bg-panel px-3.5 py-2.5 font-mono text-sm placeholder:text-muted/50"
            />
          </div>
          <div>
            <label for="manual-log-file" class="text-sm font-medium">Wipe log file</label>
            <input
              id="manual-log-file"
              type="file"
              class="mt-1.5 w-full rounded-lg border border-border bg-panel px-3.5 py-2.5 text-sm file:mr-3 file:rounded-md file:border-0 file:bg-accent/10 file:px-3 file:py-1.5 file:text-sm file:font-medium file:text-accent"
            />
          </div>
          <button id="manual-btn" type="button" class="btn btn-secondary w-full">
            <Icon name="search" size={17} /> Compare hashes locally
          </button>
        </div>
        <div id="manual-result" class="mt-6 hidden" aria-live="polite"></div>
      </div>
    </div>

    <!-- What it proves + offline fallback -->
    <div class="space-y-6">
      <div class="card p-7">
        <h2 class="font-semibold">What a match proves, and what it doesn&rsquo;t</h2>
        <ul class="mt-4 space-y-3 text-sm text-muted">
          <li class="flex gap-2.5">
            <Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" />
            The wipe log is byte-for-byte the one the certificate&rsquo;s
            SHA-256 was computed over: the record is unaltered since issuance
          </li>
          <li class="flex gap-2.5">
            <Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" />
            The outcome, serial, and method shown as verified are read from
            the hash-verified log itself, including partial or cancelled
            wipes, so altering any of them breaks the hash. A certificate
            whose summary disagrees with its own log is reported as a FAIL
          </li>
          <li class="flex gap-2.5">
            <Icon name="zap" size={16} class="mt-0.5 shrink-0 text-warning" />
            It does <strong>not</strong> prove who issued the certificate, or
            that a wipe physically occurred on the device. An offline,
            no-phone-home tool has no honest way to prove origin, so this page
            doesn&rsquo;t claim to. Provenance comes from your chain of
            custody.
          </li>
        </ul>
      </div>

      <div class="card p-7">
        <h2 class="font-semibold">Prefer to verify offline?</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          The same check works with standard tools and no browser at all. The
          wipe-log file&rsquo;s raw bytes are exactly what the certificate&rsquo;s
          hash covers, so recompute and compare:
        </p>
        <pre class="mt-3 overflow-x-auto rounded-md border border-border bg-panel p-3 font-mono text-xs text-text"><code>Get-FileHash '.\ProofWipe-XXXXXXXX-…-wipe-log.txt' -Algorithm SHA256</code></pre>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          On Linux/macOS: <span class="font-mono">sha256sum</span> the same
          file. If the output matches the &ldquo;Log SHA-256 (tamper
          evidence)&rdquo; line on the certificate, the log, and the outcome it
          documents, is exactly what ProofWipe recorded at wipe time.
        </p>
        <p class="mt-3 text-xs leading-relaxed text-muted">
          Certificates produced before the wipe-log file shipped print the hash
          but have no log file beside them; for those, verification requires
          the retained log from your records.
        </p>
      </div>

      <div class="card p-7">
        <h2 class="font-semibold">No lookups, by design</h2>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          There is no certificate database behind this page. ProofWipe is
          offline and phone-home-free, so certificates are verified
          cryptographically from the documents themselves, the same result
          here, at an auditor&rsquo;s desk, or on an air-gapped machine.
        </p>
      </div>
    </div>
  </section>

  <script>
    import {
      verifyCertificatePair,
      verifyLogAgainstHash,
      describeOutcome,
    } from '../scripts/verify-core.mjs';

    const $ = (id) => document.getElementById(id);

    const TONE = {
      ok: 'border-success/40 bg-success/10 text-success',
      warn: 'border-warning/40 bg-warning/10 text-warning',
      bad: 'border-danger/40 bg-danger/10 text-danger',
    };

    function esc(s) {
      const d = document.createElement('div');
      d.textContent = String(s ?? '');
      return d.innerHTML;
    }

    function banner(tone, title, detail) {
      return `<div class="rounded-lg border px-4 py-3 text-sm font-semibold ${TONE[tone] ?? TONE.warn}">${esc(title)}</div>` +
             (detail ? `<p class="mt-2 text-xs text-muted">${esc(detail)}</p>` : '');
    }

    function row(label, value) {
      return `<div class="flex justify-between gap-4 border-b border-border/60 py-1.5">
        <span class="text-muted">${esc(label)}</span>
        <span class="text-right font-mono break-all">${esc(value)}</span></div>`;
    }

    function show(el, html) {
      el.innerHTML = html;
      el.classList.remove('hidden');
    }

    async function readFile(input, as) {
      const f = input.files?.[0];
      if (!f) return null;
      return as === 'text' ? await f.text() : new Uint8Array(await f.arrayBuffer());
    }

    $('verify-btn')?.addEventListener('click', async () => {
      const out = $('verify-result');
      try {
        const certHtml = await readFile($('cert-file'), 'text');
        const logBytes = await readFile($('log-file'), 'bytes');
        if (!certHtml || !logBytes) {
          show(out, banner('warn', 'Select both files first.',
            'The certificate (.html) and its wipe log (…-wipe-log.txt) are needed.'));
          return;
        }
        const v = await verifyCertificatePair(certHtml, logBytes);
        if (v.status === 'unusable') {
          show(out, banner('warn', 'This certificate has no machine-readable block.', v.reason));
          return;
        }
        if (v.status !== 'pass') {
          // Two distinct failure shapes, both hard FAILs:
          //  - the log doesn't hash to the certificate's value, or
          //  - the log IS intact but the certificate's summary fields
          //    contradict it (forged display fields beside a genuine log).
          let details = `<div class="mt-4 text-xs">` +
            row('Hash on certificate', v.expected ?? '(unreadable)') +
            row('Hash of your log file', v.computed ?? '(unreadable)');
          if (v.mismatches?.length) {
            for (const m of v.mismatches) {
              details += row(`Certificate states ${m.field}`, m.stated);
              details += row(`Hash-verified log says`, m.verified);
            }
          }
          details += `</div>`;
          show(out, banner('bad', 'FAIL: this certificate cannot be trusted.',
            v.reason ?? 'The log or the certificate has been altered, or the files belong to different sessions.')
            + details);
          return;
        }
        // PASS: every field below is parsed from the HASH-VERIFIED log bytes —
        // never from the certificate's (unhashed) evidence block.
        const f = v.facts;
        const outcome = describeOutcome(f.outcome);
        const serial = f.serialNumber
          ?? (f.serialUnavailable ? `Not readable at wipe time, recorded as: ${f.serialUnavailable}` : '(not present in verified log)');
        show(out,
          banner('ok', 'PASS: the wipe log matches the certificate. The record is unaltered since issuance.') +
          `<p class="mt-2 text-xs text-muted">All fields below are read from the hash-verified log itself.</p>` +
          `<div class="mt-4 text-xs">` +
          row('Recorded outcome (verified)', outcome.label) +
          row('Certificate ID (verified)', f.certificateId ?? '(not present in verified log)') +
          row('Drive serial (verified)', serial) +
          row('Method (verified)', f.methodName ?? '(not present in verified log)') +
          row('Sanitization category (verified)', f.isPurge == null ? '(not present in verified log)' : (f.isPurge ? 'Purge (firmware sanitize)' : 'Clear (overwrite)')) +
          row('Hash on certificate', v.expected) +
          row('Hash of your log file', v.computed) +
          `</div>`);
      } catch (err) {
        show(out, banner('warn', 'Could not verify.', err?.message ?? String(err)));
      }
    });

    $('manual-btn')?.addEventListener('click', async () => {
      const out = $('manual-result');
      try {
        const logBytes = await readFile($('manual-log-file'), 'bytes');
        const pasted = $('manual-hash').value;
        if (!logBytes || !pasted.trim()) {
          show(out, banner('warn', 'Paste the hash and select the log file first.'));
          return;
        }
        const v = await verifyLogAgainstHash(logBytes, pasted);
        let factRows = '';
        if (v.match && v.facts) {
          // Same rule as the main verifier: only log-derived values are
          // presented as verified.
          const outcome = describeOutcome(v.facts.outcome);
          factRows =
            row('Recorded outcome (verified)', v.facts.outcome ? outcome.label : '(not present in verified log)') +
            row('Drive serial (verified)', v.facts.serialNumber
              ?? (v.facts.serialUnavailable ? `Not readable at wipe time, recorded as: ${v.facts.serialUnavailable}` : '(not present in verified log)')) +
            row('Method (verified)', v.facts.methodName ?? '(not present in verified log)');
        }
        show(out, (v.match
          ? banner('ok', 'PASS: the file hashes to exactly the value on the certificate.')
          : banner('bad', 'FAIL: the file does NOT hash to that value.',
              'The log has been altered, or this hash belongs to a different session.')) +
          `<div class="mt-4 text-xs">` +
          factRows +
          row('Expected (from certificate)', v.expected) +
          row('Computed (your file)', v.computed) +
          `</div>`);
      } catch (err) {
        show(out, banner('warn', 'Could not compare.', err?.message ?? String(err)));
      }
    });
  </script>
</BaseLayout>
