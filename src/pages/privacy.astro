---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { contact } from '../data/contact.ts';

/*
  PRIVACY POLICY — STUB for the owner to complete / have reviewed by counsel.
  noindex until finalized. The third parties named below are the complete list
  that touch visitor data: Formspree (contact submissions) and Cloudflare
  (hosting + cookieless Web Analytics).
*/
---

<BaseLayout title="Privacy policy" description="How the ProofWipe website handles visitor data." noindex>
  <section class="container-page max-w-3xl py-16 lg:py-20">
    <p class="text-sm font-semibold text-accent">Legal</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight">Privacy policy</h1>

    <div class="mt-6 flex items-start gap-3 rounded-lg border border-warning/40 bg-warning/10 p-4 text-sm">
      <Icon name="alert-triangle" size={18} class="mt-0.5 shrink-0 text-warning" />
      <p class="text-muted">
        <strong class="text-warning">Draft stub.</strong> This page outlines the
        factual data practices of this website and is awaiting final wording and
        legal review before publication. It is excluded from search indexing
        until finalized.
      </p>
    </div>

    <div class="mt-10 space-y-10 text-[15px] leading-relaxed text-muted">
      <section>
        <h2 class="text-xl font-semibold text-text">The short version</h2>
        <p class="mt-3">
          This website sets no cookies, runs no third-party trackers, and
          collects nothing about you unless you choose to contact us. The
          ProofWipe application itself is offline by design and sends no data
          anywhere — this policy covers only the website.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Third parties that touch data</h2>
        <p class="mt-3">Exactly two third-party services are involved in operating this site:</p>
        <ul class="mt-4 space-y-4">
          <li class="card p-5">
            <p class="font-semibold text-text">Formspree — contact form delivery</p>
            <p class="mt-1.5">
              If you submit the contact form, the contents (name, email,
              organization, message) are transmitted to Formspree, which
              delivers them to our inbox ({contact.email}). Formspree processes
              the submission per its own privacy policy. Emailing us directly
              bypasses Formspree entirely.
            </p>
          </li>
          <li class="card p-5">
            <p class="font-semibold text-text">Cloudflare — hosting and cookieless analytics</p>
            <p class="mt-1.5">
              This site is served by Cloudflare Pages, so requests pass through
              Cloudflare’s network (standard server logs: IP address, user
              agent, requested URL). We use Cloudflare Web Analytics, which is
              cookieless and aggregates page-view metrics without fingerprinting
              or tracking individual visitors across sites.
            </p>
          </li>
        </ul>
        <p class="mt-4">
          No other party receives visitor data. There is no advertising, no
          social-media embeds, and no cross-site tracking of any kind.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">What we keep and for how long</h2>
        <p class="mt-3">
          {/* TODO(owner): confirm retention practice for contact emails. */}
          Contact submissions are kept only as long as needed to handle the
          inquiry and any resulting business relationship. [Owner to confirm
          retention period.]
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Your rights</h2>
        <p class="mt-3">
          {/* TODO(owner): jurisdiction-specific wording (PIPEDA / GDPR) with counsel. */}
          To ask what we hold about you, or to have it corrected or deleted,
          email <a href={`mailto:${contact.email}`} class="text-accent underline-offset-2 hover:underline">{contact.email}</a>.
          [Owner to add jurisdiction-specific rights wording — e.g. PIPEDA for
          Canada — with counsel.]
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Changes</h2>
        <p class="mt-3">
          Material changes to this policy will be posted on this page with an
          updated effective date. [Effective date to be set at publication.]
        </p>
      </section>
    </div>
  </section>
</BaseLayout>
