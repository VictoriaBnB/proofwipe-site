---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { contact } from '../data/contact.ts';

/*
  PRIVACY POLICY: first-pass draft, PIPEDA/BC-PIPA-aware (Canadian), clearly
  marked DRAFT for counsel review. noindex stays until a lawyer signs off.
  Operator: Ryan Werk (sole proprietor), British Columbia, Canada.
  Third parties that touch data (complete list): Formspree (contact
  submissions) and Cloudflare (hosting + cookieless Web Analytics).
*/
---

<BaseLayout title="Privacy policy" description="How the ProofWipe website handles visitor data." noindex>
  <section class="container-page max-w-3xl py-16 lg:py-20">
    <p class="text-sm font-semibold text-accent">Legal</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight">Privacy policy</h1>
    <p class="mt-2 text-sm text-muted">Effective date: July 4, 2026</p>

    <div class="mt-6 flex items-start gap-3 rounded-lg border border-warning/40 bg-warning/10 p-4 text-sm">
      <Icon name="alert-triangle" size={18} class="mt-0.5 shrink-0 text-warning" />
      <p class="text-muted">
        <strong class="text-warning">DRAFT: pending legal review.</strong> This
        wording is awaiting review by counsel before it goes live. Excluded from
        search indexing until finalized.
      </p>
    </div>

    <div class="mt-10 space-y-10 text-[15px] leading-relaxed text-muted">
      <section>
        <h2 class="text-xl font-semibold text-text">The short version</h2>
        <p class="mt-3">
          This website sets no cookies, runs no third-party trackers, and
          collects no personal information unless you choose to contact us. The
          ProofWipe application itself is offline by design and transmits
          nothing. This policy covers only the website.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Who we are and scope</h2>
        <p class="mt-3">
          This policy describes how <strong class="text-text">Ryan Werk</strong>,
          a sole proprietor operating the ProofWipe product (“ProofWipe”, “we”,
          “us”, “our”), based in British Columbia, Canada, handles personal
          information in connection with the ProofWipe website (proofwipe.com and
          proofwipe.ca). We handle personal information in accordance with the
          <em>Personal Information Protection and Electronic Documents Act</em>
          (PIPEDA) and applicable provincial privacy legislation, including
          British Columbia’s <em>Personal Information Protection Act</em> (PIPA).
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">What we collect, and why</h2>
        <ul class="mt-4 space-y-4">
          <li class="card p-5">
            <p class="font-semibold text-text">Contact submissions (only if you write to us)</p>
            <p class="mt-1.5">
              If you use the contact form or email us, we receive what you send:
              your name, email address, organization (if provided), and message.
              We use it solely to respond to your inquiry and conduct any
              business relationship that follows. This is collected with your
              knowledge and consent: you initiate it.
            </p>
          </li>
          <li class="card p-5">
            <p class="font-semibold text-text">Standard server logs</p>
            <p class="mt-1.5">
              Like virtually all websites, requests pass through our hosting
              provider's network, which records standard technical data (IP
              address, user agent, requested URL, timestamp) for security and
              operational purposes.
            </p>
          </li>
          <li class="card p-5">
            <p class="font-semibold text-text">Aggregate analytics (no cookies, no tracking)</p>
            <p class="mt-1.5">
              We use Cloudflare Web Analytics, which is cookieless and measures
              aggregate page views without fingerprinting visitors or tracking
              them across sites. We cannot identify individual visitors from it.
            </p>
          </li>
        </ul>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Third parties that touch data</h2>
        <p class="mt-3">Exactly two third-party services are involved in operating this site:</p>
        <ul class="mt-4 space-y-4">
          <li class="card p-5">
            <p class="font-semibold text-text">Formspree: contact form delivery</p>
            <p class="mt-1.5">
              Contact-form submissions are transmitted to Formspree, Inc., which
              delivers them to our inbox ({contact.email}). Formspree processes
              submissions on our behalf under its own privacy policy and may
              store them on servers outside Canada (including the United
              States). Emailing us directly bypasses Formspree entirely.
            </p>
          </li>
          <li class="card p-5">
            <p class="font-semibold text-text">Cloudflare: hosting and cookieless analytics</p>
            <p class="mt-1.5">
              This site is served from Cloudflare's global network, so requests
              are processed by Cloudflare infrastructure that may be located
              outside Canada. Cloudflare also provides the cookieless analytics
              described above.
            </p>
          </li>
        </ul>
        <p class="mt-4">
          No other party receives visitor data. We do not sell, rent, or trade
          personal information. There is no advertising, no social-media
          embeds, and no cross-site tracking of any kind. Because these providers
          may process data outside Canada, that information may be subject to the
          laws of the jurisdictions where it is stored.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Retention</h2>
        <p class="mt-3">
          Contact correspondence is retained only as long as reasonably
          necessary to handle the inquiry and any resulting business
          relationship, or as required by law, after which it is deleted.
          Aggregate analytics contain no personal information and are retained
          per Cloudflare's standard retention.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Your rights</h2>
        <p class="mt-3">
          Under PIPEDA and BC PIPA you may request access to the personal
          information we hold about you, ask that it be corrected, withdraw
          consent to its continued use (subject to legal or contractual
          restrictions), or ask that it be deleted. To exercise any of these
          rights, email
          <a href={`mailto:${contact.email}`} class="text-accent underline-offset-2 hover:underline">{contact.email}</a>.
          We will respond within the timelines the applicable legislation
          prescribes. If you are unsatisfied with our response, you may complain
          to the Office of the Privacy Commissioner of Canada, or to the Office
          of the Information and Privacy Commissioner for British Columbia.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Safeguards</h2>
        <p class="mt-3">
          The site is served exclusively over HTTPS with strict transport
          security and a restrictive content-security policy. Contact
          correspondence is accessible only to the people who need it to
          respond.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Changes</h2>
        <p class="mt-3">
          Material changes to this policy will be posted on this page with an
          updated effective date.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">Contact</h2>
        <p class="mt-3">
          Ryan Werk is the individual accountable for personal information
          handled under this policy. Questions or privacy requests:
          <a href={`mailto:${contact.email}`} class="text-accent underline-offset-2 hover:underline">{contact.email}</a>.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>
