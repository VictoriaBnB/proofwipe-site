---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" noindex canonicalPath="/404">
  <section data-pagefind-ignore class="container-page flex min-h-[60vh] flex-col items-center justify-center py-24 text-center">
    <p class="font-mono text-sm text-accent">404</p>
    <h1 class="mt-3 text-3xl font-bold tracking-tight sm:text-4xl">
      This sector couldn’t be found
    </h1>
    <p class="mt-4 max-w-md text-muted">
      The page you’re looking for has been moved, renamed, or never existed.
      Let’s get you back to safe ground.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="btn btn-primary">Back to home</a>
      <a href="/features" class="btn btn-secondary">Explore features</a>
    </div>
  </section>
</BaseLayout>
