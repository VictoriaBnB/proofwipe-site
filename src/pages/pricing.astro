---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

/*
  PRICING: Free vs Pro. Per owner decision (2026-07-03): NO price numbers in
  v1. Pro and volume/government licensing both route to "Contact us".
  Tier contents mirror the shipped license gating (LicenseService).
*/

const description =
  'ProofWipe Free covers NIST Clear with 10% verification on a single drive. Pro unlocks firmware Purge, full verification, multi-drive batch, and clean PDF + HTML certificates. Contact us for Pro and volume or government licensing.';

type Cell = string | boolean;
const rows: { label: string; free: Cell; pro: Cell }[] = [
  { label: 'Sanitization methods', free: 'NIST Clear (overwrite)', pro: 'All methods, including firmware Purge (ATA SANITIZE / Secure Erase, NVMe Sanitize / Format)' },
  { label: 'Read-back verification', free: '10% sampling', pro: '1%, 10%, or 100% sampling' },
  { label: 'Drives per session', free: 'Single drive', pro: 'Multi-drive parallel batch' },
  { label: 'Certificates', free: 'Watermarked HTML', pro: 'Clean PDF + HTML, no watermark' },
  { label: 'Certificate for every outcome (incl. partial wipes)', free: true, pro: true },
  { label: 'Fail-closed system-disk protection', free: true, pro: true },
  { label: 'HPA/DCO hidden-area detection', free: true, pro: true },
  { label: 'BitLocker detection', free: true, pro: true },
  { label: 'Bootable WinPE edition', free: true, pro: true },
  { label: 'Offline license keys, no phone-home', free: true, pro: true },
];

function isBool(c: Cell): c is boolean {
  return typeof c === 'boolean';
}
---

<BaseLayout title="Pricing" description={description}>
  <!-- Header -->
  <section class="border-b border-border bg-panel/40">
    <div class="container-page py-16 text-center lg:py-20">
      <p class="text-sm font-semibold text-accent">Pricing</p>
      <h1 class="mx-auto mt-2 max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">
        Start free. Upgrade when the bench gets busy.
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-muted">
        The Free tier is a complete, honest workflow, not a crippled demo. Pro
        unlocks firmware Purge, full verification, batch, and clean certificates.
      </p>
    </div>
  </section>

  <!-- Tier cards -->
  <section class="container-page py-16 lg:py-20">
    <div class="mx-auto grid max-w-4xl gap-6 lg:grid-cols-2">
      <!-- Free -->
      <div class="card flex flex-col p-8">
        <h2 class="text-xl font-semibold">Free</h2>
        <p class="mt-1 text-sm text-muted">For evaluation and occasional single-drive wipes</p>
        <p class="mt-6 text-4xl font-bold">$0</p>
        <ul class="mt-6 flex-1 space-y-3 text-sm text-muted">
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> NIST Clear (overwrite) sanitization</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> 10% read-back verification</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> Single drive per session</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> Watermarked HTML certificate (every outcome)</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> All safety features: fail-closed protection, two-step arming, HPA/DCO and BitLocker detection</li>
        </ul>
        <a href="/download" class="btn btn-secondary mt-8 w-full">Download free</a>
      </div>

      <!-- Pro -->
      <div class="card relative flex flex-col border-accent/50 p-8">
        <span class="absolute -top-3 right-6 rounded-full border border-accent/50 bg-accent/15 px-3 py-1 text-xs font-semibold text-accent">
          For production benches
        </span>
        <h2 class="text-xl font-semibold">Pro</h2>
        <p class="mt-1 text-sm text-muted">For ITAD vendors, MSPs, and enterprise decommissioning</p>
        <p class="mt-6 text-4xl font-bold">Contact us</p>
        <ul class="mt-6 flex-1 space-y-3 text-sm text-muted">
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> Everything in Free, plus:</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> Firmware Purge: ATA SANITIZE / Secure Erase, NVMe Sanitize / Format</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> All verification levels: 1%, 10%, 100%</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> Multi-drive parallel batch with isolated per-drive sessions</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> Clean PDF + HTML certificates, no watermark</li>
          <li class="flex gap-2.5"><Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" /> Offline license key, applied live, no phone-home</li>
        </ul>
        <a href="/about#contact" class="btn btn-primary mt-8 w-full">Talk to sales</a>
      </div>
    </div>

    <!-- Volume / gov -->
    <div class="card mx-auto mt-6 flex max-w-4xl flex-col items-start gap-4 p-6 sm:flex-row sm:items-center sm:justify-between">
      <div>
        <h2 class="font-semibold">Volume &amp; government licensing</h2>
        <p class="mt-1 text-sm text-muted">
          Fleet decommissioning, multi-seat benches, and public-sector
          procurement, including Canadian public-sector requirements.
        </p>
      </div>
      <a href="/about#contact" class="btn btn-secondary shrink-0">Contact us</a>
    </div>
  </section>

  <!-- Comparison table -->
  <section class="border-t border-border bg-panel/40">
    <div class="container-page py-16 lg:py-20">
      <h2 class="text-3xl font-bold tracking-tight">Free vs Pro, in detail</h2>

      <div class="mt-10 overflow-x-auto">
        <table class="w-full min-w-[42rem] border-collapse text-left">
          <caption class="sr-only">Feature comparison between ProofWipe Free and Pro</caption>
          <thead>
            <tr class="border-b border-border">
              <th scope="col" class="py-3 pr-4 text-sm font-medium text-muted">Capability</th>
              <th scope="col" class="px-4 py-3 text-center text-sm font-semibold">Free</th>
              <th scope="col" class="px-4 py-3 text-center text-sm font-semibold text-accent">Pro</th>
            </tr>
          </thead>
          <tbody>
            {
              rows.map((r) => (
                <tr class="border-b border-border/60">
                  <th scope="row" class="max-w-md py-3.5 pr-4 text-sm font-normal text-text">
                    {r.label}
                  </th>
                  {[r.free, r.pro].map((cell, i) => (
                    <td
                      class:list={[
                        'px-4 py-3.5 text-center text-sm',
                        i === 1 ? 'bg-accent/5' : '',
                      ]}
                    >
                      {isBool(cell) ? (
                        cell ? (
                          <span class="inline-flex text-success">
                            <Icon name="check" size={18} />
                            <span class="sr-only">Included</span>
                          </span>
                        ) : (
                          <span class="inline-flex text-danger">
                            <Icon name="x" size={18} />
                            <span class="sr-only">Not included</span>
                          </span>
                        )
                      ) : (
                        <span class="text-muted">{cell}</span>
                      )}
                    </td>
                  ))}
                </tr>
              ))
            }
          </tbody>
        </table>
      </div>

      <p class="mt-6 max-w-2xl text-sm text-muted">
        Licensing is enforced with offline, signed license keys: no activation
        server, no phone-home. Gated options stay visible in the app, greyed out
        with the reason stated.
      </p>
    </div>
  </section>

  <!-- FAQ-ish CTA -->
  <section class="border-t border-border">
    <div class="container-page py-16 text-center lg:py-20">
      <h2 class="text-3xl font-bold tracking-tight">Not sure which tier fits?</h2>
      <p class="mx-auto mt-4 max-w-xl text-muted">
        Tell us about your bench (drive volumes, media types, and reporting
        needs), and we’ll point you at the right setup.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href="/about#contact" class="btn btn-primary">Talk to sales</a>
        <a href="/download" class="btn btn-secondary">Try Free first</a>
      </div>
    </div>
  </section>
</BaseLayout>
