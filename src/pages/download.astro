---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { download } from '../data/download.ts';

/*
  DOWNLOAD: links out to GitHub Releases (the binary is never hosted inline).
  Release URL / version / SHA-256 are PLACEHOLDERS from src/data/download.ts
  until the owner provides real values (download.isPlaceholder gates a visible
  notice so a placeholder can never silently look real).
*/

const description =
  'Download ProofWipe for Windows 10/11: a portable, self-contained .exe that runs from a USB stick. Hosted on GitHub Releases, with the SHA-256 checksum published for integrity verification.';
---

<BaseLayout title="Download" description={description}>
  <!-- Header -->
  <section class="border-b border-border bg-panel/40">
    <div class="container-page py-16 lg:py-20">
      <p class="text-sm font-semibold text-accent">Download</p>
      <h1 class="mt-2 max-w-3xl text-4xl font-bold tracking-tight sm:text-5xl">
        Get ProofWipe
      </h1>
      <p class="mt-5 max-w-2xl text-lg text-muted">
        One portable .exe: no installer, no dependencies, no telemetry.
        Downloads are hosted on GitHub Releases.
      </p>
    </div>
  </section>

  <section class="container-page py-16 lg:py-20">
    <div class="grid gap-8 lg:grid-cols-[1.1fr_0.9fr]">
      <!-- Download card -->
      <div>
        {
          download.isPlaceholder && (
            <div class="mb-6 flex items-start gap-3 rounded-lg border border-warning/40 bg-warning/10 p-4 text-sm">
              <Icon name="alert-triangle" size={18} class="mt-0.5 shrink-0 text-warning" />
              <p class="text-muted">
                <strong class="text-warning">Pre-launch placeholder.</strong> The
                release link and checksum below are not live yet. They will be
                replaced with the real GitHub Release and SHA-256 before this
                page is published.
              </p>
            </div>
          )
        }

        <div class="card p-8">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center gap-3">
              <img src="/logo.png" alt="" width="44" height="44" class="h-11 w-11 rounded-lg" />
              <div>
                <h2 class="text-xl font-semibold">
                  {download.fileName}
                  <span class="ml-2 align-middle font-mono text-sm text-muted">{download.version}</span>
                </h2>
                <p class="text-sm text-muted">Windows 10 / 11 (x64) · portable single file</p>
              </div>
            </div>
            <a href={download.latestAssetUrl} rel="external noopener" class="btn btn-primary">
              Download from GitHub <Icon name="arrow-right" size={17} />
            </a>
          </div>

          <!-- Checksum -->
          <div class="mt-7 rounded-lg border border-border bg-panel p-5">
            <p class="flex items-center gap-2 text-sm font-semibold">
              <Icon name="fingerprint" size={16} class="text-accent" /> SHA-256 checksum
            </p>
            {
              download.sha256 ? (
                <p class="mt-2 break-all font-mono text-xs leading-relaxed text-muted">
                  {download.sha256}
                </p>
              ) : (
                <p class="mt-2 font-mono text-xs text-warning">
                  pending: published with the release
                </p>
              )
            }
            <p class="mt-3 text-xs leading-relaxed text-muted">
              Verify your download before running it. In PowerShell:
            </p>
            <pre class="mt-2 overflow-x-auto rounded-md border border-border bg-panel p-3 font-mono text-xs text-text"><code>Get-FileHash .\{download.fileName} -Algorithm SHA256</code></pre>
            <p class="mt-2 text-xs text-muted">
              The output must match the checksum above exactly. If it doesn’t,
              delete the file and download again from GitHub only.
            </p>
          </div>

          <p class="mt-5 text-sm text-muted">
            All releases and their checksums live on the
            <a href={download.releasesUrl} rel="external noopener" class="text-accent underline-offset-2 hover:underline">GitHub Releases page</a>.
            ProofWipe is only distributed there. Treat copies from anywhere
            else as untrusted.
          </p>
        </div>

        <!-- First run -->
        <div class="card mt-6 p-7">
          <h2 class="font-semibold">First run</h2>
          <ol class="mt-4 list-decimal space-y-2.5 pl-5 text-sm leading-relaxed text-muted">
            <li>Copy <span class="font-mono text-text">{download.fileName}</span> to a USB stick (or run it from anywhere on the machine).</li>
            <li>Launch it. Windows will ask for Administrator elevation; that’s required for raw disk access.</li>
            <li>The Free tier is active immediately: NIST Clear, 10% verification, single drive. Pro keys are applied in-app under “Manage license”, fully offline.</li>
          </ol>
        </div>
      </div>

      <!-- Requirements sidebar -->
      <aside>
        <div class="card p-7">
          <h2 class="font-semibold">System requirements</h2>
          <ul class="mt-4 space-y-3 text-sm text-muted">
            {
              download.requirements.map((r) => (
                <li class="flex gap-2.5">
                  <Icon name="check" size={16} class="mt-0.5 shrink-0 text-success" />
                  {r}
                </li>
              ))
            }
          </ul>
        </div>

        <div class="card mt-6 p-7">
          <h2 class="font-semibold">Why Administrator?</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">
            Sanitization requires raw, unbuffered access to physical drives:
            something Windows only grants to elevated processes. ProofWipe
            declares this up front in its manifest rather than asking mid-task.
          </p>
        </div>

        <div class="card mt-6 p-7">
          <h2 class="font-semibold">Wiping the system disk?</h2>
          <p class="mt-3 text-sm leading-relaxed text-muted">
            The desktop app will refuse to touch the disk Windows is running
            from. That’s by design. Use the
            <a href="/bootable-usb" class="text-accent underline-offset-2 hover:underline">bootable WinPE edition</a>
            to sanitize system disks and sealed devices.
          </p>
        </div>
      </aside>
    </div>
  </section>
</BaseLayout>
