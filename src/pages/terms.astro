---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import { contact } from '../data/contact.ts';

/*
  TERMS — STUB for the owner to complete / have reviewed by counsel.
  noindex until finalized. Section headings sketch the expected shape; bracketed
  items are for the owner. The software licence itself (EULA) ships with the
  app and is separate from these website terms.
*/
---

<BaseLayout title="Terms of use" description="Terms of use for the ProofWipe website." noindex>
  <section class="container-page max-w-3xl py-16 lg:py-20">
    <p class="text-sm font-semibold text-accent">Legal</p>
    <h1 class="mt-2 text-4xl font-bold tracking-tight">Terms of use</h1>

    <div class="mt-6 flex items-start gap-3 rounded-lg border border-warning/40 bg-warning/10 p-4 text-sm">
      <Icon name="alert-triangle" size={18} class="mt-0.5 shrink-0 text-warning" />
      <p class="text-muted">
        <strong class="text-warning">Draft stub.</strong> Section structure is in
        place for the owner and counsel to complete. Excluded from search
        indexing until finalized.
      </p>
    </div>

    <div class="mt-10 space-y-10 text-[15px] leading-relaxed text-muted">
      <section>
        <h2 class="text-xl font-semibold text-text">1. Scope</h2>
        <p class="mt-3">
          These terms govern use of the ProofWipe website. Use of the ProofWipe
          software is governed by its end-user licence agreement, which
          accompanies the software. [Owner: confirm EULA reference.]
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">2. Downloads and integrity</h2>
        <p class="mt-3">
          Software is distributed exclusively via the official GitHub Releases
          page linked from this site. Verify the published SHA-256 checksum
          before running any download. Copies obtained elsewhere are not ours
          and are used at your own risk.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">3. Responsible use</h2>
        <p class="mt-3">
          ProofWipe permanently destroys data by design. You are responsible for
          ensuring you are authorized to sanitize any device you target, and for
          selecting a sanitization category appropriate to your data and
          policies. [Owner: expand with counsel.]
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">4. No warranty; limitation of liability</h2>
        <p class="mt-3">
          [Owner: standard warranty disclaimer and liability limitation, drafted
          with counsel. Note the existing site-wide statement that ProofWipe
          implements published standards and is not a third-party-certified
          product.]
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">5. Intellectual property</h2>
        <p class="mt-3">
          The ProofWipe name, logo, and site content are the property of their
          owner. [Owner: entity name and jurisdiction.]
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">6. Governing law</h2>
        <p class="mt-3">[Owner: jurisdiction, with counsel.]</p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-text">7. Contact</h2>
        <p class="mt-3">
          Questions about these terms:
          <a href={`mailto:${contact.email}`} class="text-accent underline-offset-2 hover:underline">{contact.email}</a>.
        </p>
      </section>
    </div>
  </section>
</BaseLayout>
