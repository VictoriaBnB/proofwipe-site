---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.ts';
import { analytics, isAnalyticsEnabled } from '../data/analytics.ts';

interface Props {
  title: string;
  /** Exact <title>/OG/Twitter title, bypassing the "· ProofWipe" suffix. Opt-in. */
  titleTag?: string;
  description?: string;
  /** Path-relative canonical (e.g. "/features"). Defaults to current URL. */
  canonicalPath?: string;
  /** Social share image path under /public. */
  ogImage?: string;
  /** Open Graph type — 'website' (default) or 'article' for guides/articles. */
  ogType?: string;
  /** Set true on legal/utility pages to discourage indexing. */
  noindex?: boolean;
  /** Optional JSON-LD object injected into <head>. */
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  titleTag,
  description = site.description,
  canonicalPath,
  ogImage = '/og/proofwipe-og.png',
  ogType = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

/**
 * Normalise to a clean, extensionless canonical path (build uses
 * format:'file', so pathnames come through as "/features.html" / "/index.html").
 * Cloudflare serves these without the extension.
 */
function cleanPath(p: string): string {
  let out = p.replace(/index\.html$/, '').replace(/\.html$/, '');
  if (out.length > 1 && out.endsWith('/')) out = out.slice(0, -1);
  return out === '' ? '/' : out;
}

const canonical = new URL(
  canonicalPath ?? cleanPath(Astro.url.pathname),
  site.url
).href;
const ogImageUrl = new URL(ogImage, site.url).href;
const fullTitle =
  titleTag ??
  (title === site.name ? `${site.name}: ${site.tagline}` : `${title} · ${site.name}`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <meta name="theme-color" content="#FFFFFF" />
    <meta name="color-scheme" content="light" />

    <!-- Favicons -->
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Pagefind search UI styles (self-hosted; created at build by pagefind) -->
    <link rel="stylesheet" href="/pagefind/pagefind-ui.css" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter/X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    {
      jsonLd && (
        <script
          type="application/ld+json"
          set:html={JSON.stringify(jsonLd)}
        />
      )
    }

    {/*
      Cloudflare Web Analytics (cookieless). Rendered ONLY when a site token is
      configured in src/data/analytics.ts (option B). If the owner enables
      dashboard auto-injection instead (option A), the token stays empty and
      nothing renders here. Beacon host is allowed in the CSP.
    */}
    {
      isAnalyticsEnabled && (
        <script
          defer
          src="https://static.cloudflareinsights.com/beacon.min.js"
          data-cf-beacon={JSON.stringify({ token: analytics.token })}
          is:inline
        />
      )
    }
  </head>
  <body class="min-h-screen flex flex-col bg-bg text-text">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-50 focus:rounded-lg focus:bg-accent focus:px-4 focus:py-2 focus:text-white"
    >
      Skip to content
    </a>
    <Nav />
    <main id="main" class="flex-1" data-pagefind-body>
      <slot />
    </main>
    <Footer />

    <!--
      Pagefind search: static, self-hosted, no backend, no external calls.
      The UI script (self) exposes window.PagefindUI; the init is a static
      self-hosted file (public/js/search-init.js) so no inline script is needed
      under the strict CSP. Files under /pagefind/ are generated at build.
    -->
    <script src="/pagefind/pagefind-ui.js" is:inline></script>
    <script src="/js/search-init.js" is:inline></script>
  </body>
</html>
