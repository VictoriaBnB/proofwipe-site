---
import { footerNav, site } from '../data/site.ts';
import { claims } from '../data/claims.ts';

const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-panel">
  <div class="container-page py-12">
    <div class="grid gap-10 md:grid-cols-3 lg:grid-cols-[1.4fr_repeat(5,1fr)]">
      <div class="max-w-xs">
        <a href="/" class="flex items-center gap-2.5" aria-label={`${site.name} home`}>
          <img src="/logo.png" alt="" width="28" height="28" class="h-7 w-7 rounded-md" />
          <span class="text-base font-semibold">{site.name}</span>
        </a>
        <p class="mt-3 text-sm text-muted">{site.tagline}</p>
        <p class="mt-4 text-xs leading-relaxed text-muted">
          {/* Approved disclaimer, safe to show. */}
          {claims.notCertified.text}
        </p>
      </div>

      {
        footerNav.map((group) => (
          <nav aria-label={group.heading}>
            <h2 class="text-xs font-semibold uppercase tracking-wider text-muted">
              {group.heading}
            </h2>
            <ul class="mt-3 flex flex-col gap-2">
              {group.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-muted transition-colors hover:text-text"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        ))
      }
    </div>

    <div
      class="mt-10 flex flex-col gap-3 border-t border-border pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <p>&copy; {year} {site.name}. All rights reserved.</p>
      <p>
        Windows 10 / 11 · Runs from USB · Requires Administrator ·{' '}
        <span class="text-muted">Offline by design</span>
      </p>
    </div>
  </div>
</footer>
